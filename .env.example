# Database
DATABASE_URL="postgresql://user:password@localhost:5432/farmwise?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-min-32-chars"
JWT_REFRESH_SECRET="change-me-different-from-jwt-secret"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
STORAGE_PROVIDER="cloudinary"

# Pesapal (https://developer.pesapal.com)
# Sandbox demo creds available at developer.pesapal.com/api3-demo-keys.txt
PESAPAL_ENV="sandbox"                  # sandbox | production
PESAPAL_CONSUMER_KEY=""
PESAPAL_CONSUMER_SECRET=""
PESAPAL_IPN_ID=""                      # filled after running scripts/pesapal-register-ipn.ts
PESAPAL_CURRENCY="UGX"                 # UGX | KES | TZS | USD
# Public URL where Pesapal hits our IPN endpoint. Used by the registration script.
PESAPAL_IPN_URL="https://aan.academy/api/v1/payments/ipn"
# Public base URL for the API. Used in checkout flow only if needed.
PUBLIC_API_URL="https://aan.academy"

# Email (Resend)
RESEND_API_KEY=""

# SMS (Africa's Talking)
AT_API_KEY=""
AT_USERNAME="sandbox"

# App
FRONTEND_URL="https://aan.academy"
PORT="4000"
"
